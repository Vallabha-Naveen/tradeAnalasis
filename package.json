{
  "name": "telegram-trade-analyzer",
  "version": "0.2.0",
  "description": "Automatically analyze trading screenshots posted in Telegram channels and execute option-selling trades via Fyers API",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "prelive-trade": "tsc",
    "preanalyze": "tsc",
    "prebacktest": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rm -rf dist",
    "query": "node dist/scripts/query.js",
    "reprocess": "node dist/scripts/reprocess.js",
    "analyze": "node dist/scripts/analyze.js",
    "calibrate": "node dist/scripts/calibrateWhitespace.js",
    "migrate-orders": "node dist/scripts/migrateOrders.js",
    "fyers-auth": "node dist/scripts/fyersAuth.js",
    "live-trade": "node dist/scripts/liveTrade.js",
    "backtest": "node dist/scripts/backtestOptionType.js"
  },
  "keywords": [
    "telegram",
    "trading",
    "analyzer",
    "ocr",
    "options",
    "fyers"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "fyers-api-v3": "^2.0.0",
    "input": "^1.0.1",
    "sharp": "^0.33.5",
    "telegraf": "^4.16.3",
    "telegram": "^2.22.2",
    "tesseract.js": "^5.1.1",
    "winston": "^3.17.0",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
