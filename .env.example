# ============================================================================
# Telegram API
# ============================================================================
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_PATH=session.telegram-trade-analyzer
CHANNEL_USERNAME=your_channel_username

# ============================================================================
# Paths
# ============================================================================
DATABASE_PATH=./database/trades.db
DOWNLOAD_DIRECTORY=./downloads/raw
LOG_LEVEL=info

# ============================================================================
# History download — only download messages posted on or after this date
# Format: YYYY-MM-DD (default: 2025-01-01)
# ============================================================================
HISTORY_START_DATE=2025-01-01

# ============================================================================
# Parser
# ============================================================================
PARSER_VERSION=0.2.0

# ============================================================================
# Fyers API
# ============================================================================
FYERS_APP_ID=your_app_id
FYERS_APP_SECRET=your_app_secret
FYERS_REDIRECT_URI=http://localhost:8080
# Tokens are auto-managed — do NOT set these manually.
# They are saved to config/fyers-tokens.json after running `npm run fyers-auth`.
# FYERS_ACCESS_TOKEN=
# FYERS_REFRESH_TOKEN=

# ============================================================================
# Trading mode
# ============================================================================
# DRY_RUN=true  → Orders are computed and logged but NOT placed on Fyers.
#                 Lets you test the full pipeline (OCR → analysis → risk
#                 check → order plan) safely with live market data.
# DRY_RUN=false → Real SELL orders are placed on Fyers (option selling).
DRY_RUN=true

# ============================================================================
# Risk management
# ============================================================================
MAX_ORDER_VALUE=50000
DAILY_LOSS_LIMIT=10000
MAX_DAILY_TRADES=20
MAX_OPEN_POSITIONS=5
COOLDOWN_MINUTES=5

# Minimum analysis confidence (0-100) required to place a trade.
# Signals below this threshold are logged but skipped.
CONFIDENCE_THRESHOLD=70

# ============================================================================
# Lot sizes (NSE — verify quarterly, NSE revises these periodically)
# As of Nov 2024: NIFTY=75, BANKNIFTY=35
# ============================================================================
NIFTY_LOT_SIZE=75
BANKNIFTY_LOT_SIZE=35

# ============================================================================
# Market hours (IST, 24-hour format HH:MM)
# No trades are placed outside this window. Orders that would be placed
# outside the window are rejected (not queued).
# Default: 09:20 (no trades in the first 5 min of high volatility) to 15:15
# (15 min before close to allow square-off).
# ============================================================================
MARKET_OPEN_TIME=09:20
MARKET_CLOSE_TIME=15:15

# ============================================================================
# Static IP proxy (for Fyers IP whitelisting)
# ----------------------------------------------------------------------------
# Fyers requires API calls to come from a whitelisted static IP. If you're
# running on a local machine with a dynamic IP, use a proxy service like
# Fixie (https://usefixie.com) to route Fyers traffic through a static IP.
#
# Only Fyers API calls go through the proxy. Telegram and VLM traffic stay
# direct (they don't check IP).
#
# SETUP:
#   1. Sign up at https://usefixie.com (~$9/month)
#   2. Get your proxy URL from the Fixie dashboard
#   3. Set it here: http://USERNAME:PASSWORD@proxy.usefixie.com:80
#   4. Whitelist the Fixie static IP in your Fyers API dashboard
#   5. Uncomment the line below
# ============================================================================
# FIXIE_URL=http://your-username:your-password@proxy.usefixie.com:80

# ============================================================================
# Option-type detector for live trading
# Controls how CE/PE is detected from screenshots:
#   vlm       — VLM (glm-4v) primary, OCR fallback if VLM fails (DEFAULT)
#   ocr       — OCR only (no VLM dependency, lower accuracy)
#   vlm-only  — VLM only, skip trade if VLM fails (no OCR fallback)
# Requires .z-ai-config file with BigModel API key when using vlm or vlm-only.
# ============================================================================
OPTION_TYPE_DETECTOR=vlm

# ============================================================================
# VLM detector settings (used by both backtest and live trading)
# Delay between ZAI Vision API calls, in milliseconds.
# Increase if you hit rate limits on your ZAI tier.
# ============================================================================
VLM_CALL_DELAY_MS=500

# Vision model to use for the backtest VLM detector.
# BigModel (Zhipu AI) public API options:
#   glm-4v       — basic vision, fast, cheap (default)
#   glm-4v-plus  — better accuracy, slightly slower
#   glm-4.5v     — newest, best accuracy
# Override only if you want to test a different model.
VLM_MODEL=glm-4v
