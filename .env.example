# Telegram API
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_PATH=session.telegram-trade-analyzer
CHANNEL_USERNAME=your_channel_username

# Paths
DATABASE_PATH=./database/trades.db
DOWNLOAD_DIRECTORY=./downloads/raw
LOG_LEVEL=info

# History download - only download messages after this date
# Format: YYYY-MM-DD (default: 2025-01-01)
HISTORY_START_DATE=2025-01-01

# Parser
PARSER_VERSION=0.2.0